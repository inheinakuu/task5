<!doctype html>
<html>
<head>
    <title>Music Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tone@15.1.22/build/Tone.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/seedrandom@3.0.5/seedrandom.min.js"></script>
</head>
<body>
<div class="container mt-4">
    <h1 class="mb-4">Music Store</h1>
    <div class="bg-light border rounded p-3 mb-3 d-flex gap-3 align-items-end flex-wrap">
        <div>
            <label class="form-label">Language</label>
            <select class="form-select" id="language">
                <option value="en">English (USA)</option>
                <option value="de">German (Germany)</option>
            </select>
        </div>
        <div>
            <label class="form-label">Seed</label>
            <input class="form-control" id="seed" value="12345">
        </div>
        <button class="btn btn-outline-primary" id="randomSeed" type="button">
            Random seed
        </button>
        <div>
            <label class="form-label">Likes</label>
            <input class="form-control" id="likes" type="number" min="0" max="10" step="0.1" value="3">
        </div>
        <div>
            <label class="form-label d-block">View</label>
            <div class="btn-group">
                <button id="tableMode" class="btn btn-primary" title="Table view" type="button">
                    ☷
                </button>
                <button id="galleryMode" class="btn btn-outline-primary" title="Gallery view" type="button">
                    ⊞
                </button>
            </div>
        </div>
    </div>
    <div id="tableView">
        <table class="table table-hover align-middle bg-white">
            <thead>
                <tr>
                    <th></th>
                    <th>#</th>
                    <th>Song</th>
                    <th>Artist</th>
                    <th>Album</th>
                    <th>Genre</th>
                    <th>Likes</th>
                </tr>
            </thead>
            <tbody id="songs"></tbody>
        </table>
        <div class="d-flex gap-2 align-items-center">
            <button class="btn btn-outline-primary" id="previousPage" type="button">
                Previous
            </button>
            <span id="pageNumber">Page 1</span>
            <button class="btn btn-outline-primary" id="nextPage" type="button">
                Next
            </button>
        </div>
    </div>
    <div id="galleryView" class="row g-3 d-none"></div>
</div>
<script>
    let currentPage = 1
    let isLoading = false
    let viewMode = 'table'
    const languageInput = document.getElementById('language')
    const seedInput = document.getElementById('seed')
    const likesInput = document.getElementById('likes')
    const songsTable = document.getElementById('songs')
    const tableView = document.getElementById('tableView')
    const galleryView = document.getElementById('galleryView')
    const pageNumber = document.getElementById('pageNumber')
    const tableModeButton = document.getElementById('tableMode')
    const galleryModeButton = document.getElementById('galleryMode')
    const nextPageButton = document.getElementById('nextPage')
    const previousPageButton = document.getElementById('previousPage')
    const randomSeedButton = document.getElementById('randomSeed')
    function getSongsUrl() {
        const params = new URLSearchParams({
            language: languageInput.value,
            seed: seedInput.value,
            likes: likesInput.value,
            page: currentPage
        })
        return '/api/songs?' + params.toString()
    }
    function getReviews(song) {
        return song.reviews && song.reviews.length
            ? song.reviews.join('<br>')
            : 'No reviews yet.'
    }
    function getMelody(id) {
        const rng = new Math.seedrandom(`${seedInput.value}-${id}`)
        const notes = ['C4', 'D4', 'E4', 'G4', 'A4', 'C5']
        const melody = []
        for (let i = 0; i < 8; i++) {
            melody.push(notes[Math.floor(rng() * notes.length)])
        }
        return melody
    }
    async function playSong(event, id) {
        event.stopPropagation()
        await Tone.start()
        const synth = new Tone.Synth().toDestination()
        const now = Tone.now()
        getMelody(id).forEach((note, index) => {
            synth.triggerAttackRelease(note, '8n', now + index * 0.25)
        })
    }
    function toggleDetails(id) {
        const row = document.getElementById(`details-${id}`)
        row.classList.toggle('d-none')
    }
    function getTableRows(song) {
        return `
            <tr onclick="toggleDetails(${song.id})" style="cursor: pointer;">
                <td>⌄</td>
                <td><strong>${song.id}</strong></td>
                <td>${song.title}</td>
                <td>${song.artist}</td>
                <td>${song.album}</td>
                <td>${song.genre}</td>
                <td>♡ ${song.likes}</td>
            </tr>
            <tr id="details-${song.id}" class="d-none">
                <td colspan="7" style="background: #f8fbff;">
                    <div class="d-flex gap-4 p-4">
                        <div class="text-center">
                            <img
                                class="rounded mb-3"
                                style="width: 210px;"
                                src="data:image/svg+xml;charset=utf-8,${encodeURIComponent(song.cover)}"
                            >
                            <div>
                                <button class="btn btn-primary btn-sm rounded-pill px-3" type="button">
                                    👍 ${song.likes}
                                </button>
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <h2 class="mb-0">${song.title}</h2>
                                <button
                                    class="btn btn-primary rounded-circle"
                                    onclick="playSong(event, ${song.id})"
                                    type="button"
                                >
                                    ▶
                                </button>
                                <span class="text-secondary">🔊</span>
                                <div class="progress flex-grow-1" style="height: 6px;">
                                    <div class="progress-bar" style="width: 15%;"></div>
                                </div>
                                <span class="badge bg-secondary">0:12</span>
                            </div>
                            <div class="fs-5 text-secondary mb-2">
                                from <strong>${song.album}</strong>
                                by <strong><em>${song.artist}</em></strong>
                            </div>
                            <div class="text-secondary mb-3">
                                ${song.genre}
                            </div>
                            <div class="border rounded bg-white">
                                <div class="d-flex border-bottom">
                                    <div class="px-4 py-2 border-end fw-bold">
                                        Reviews
                                    </div>
                                </div>
                                <div class="p-3">
                                    ${getReviews(song)}
                                </div>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>
        `
    }
    function getGalleryCard(song) {
    return `
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 border-0 text-white rounded-4 p-2"
                 style="background: #22252d;">
                <img
                    class="card-img-top rounded-4"
                    src="data:image/svg+xml;charset=utf-8,${encodeURIComponent(song.cover)}"
                >
                <div class="card-body px-2 pb-2">
                    <div class="text-secondary small mb-2">#${song.id}</div>
                    <h5 class="mb-1 text-truncate">
                        ${song.title}
                    </h5>
                    <div class="text-secondary text-truncate mb-3">
                        ${song.artist}
                    </div>
                    <div class="small text-secondary text-truncate">
                        Album • ${song.album}
                    </div>
                    <div class="small text-secondary text-truncate mb-3">
                        Genre • ${song.genre}
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small text-secondary">
                            ♡ ${song.likes}
                        </span>
                        <button
                            class="btn btn-success rounded-circle d-flex align-items-center justify-content-center"
                            style="width: 42px; height: 42px;"
                            onclick="playSong(event, ${song.id})"
                            type="button"
                        >
                            ▶
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `
}
    function renderTable(songs) {
        songsTable.innerHTML = songs.map(getTableRows).join('')
    }
    function renderGallery(songs) {
        if (currentPage === 1) {
            galleryView.innerHTML = ''
        }
        galleryView.innerHTML += songs.map(getGalleryCard).join('')
    }
    function renderSongs(songs) {
        if (viewMode === 'table') {
            renderTable(songs)
            return
        }
        renderGallery(songs)
    }
    function loadSongs() {
        isLoading = true
        pageNumber.textContent = `Page ${currentPage}`
        fetch(getSongsUrl())
            .then(response => response.json())
            .then(renderSongs)
            .finally(() => {
                isLoading = false
            })
    }
    function resetPage() {
        currentPage = 1
        galleryView.innerHTML = ''
        window.scrollTo(0, 0)
        loadSongs()
    }
    function updateView() {
        const isGallery = viewMode === 'gallery'
        tableView.classList.toggle('d-none', isGallery)
        galleryView.classList.toggle('d-none', !isGallery)
        tableModeButton.className = isGallery
            ? 'btn btn-outline-primary'
            : 'btn btn-primary'
        galleryModeButton.className = isGallery
            ? 'btn btn-primary'
            : 'btn btn-outline-primary'
        nextPageButton.disabled = isGallery
        previousPageButton.disabled = isGallery
    }
    function loadNextGalleryPage() {
        if (viewMode !== 'gallery' || isLoading) {
            return
        }
        const nearBottom =
            window.innerHeight + window.scrollY >
            document.body.offsetHeight - 300
        if (nearBottom) {
            currentPage++
            loadSongs()
        }
    }
    function setTableMode() {
        viewMode = 'table'
        resetPage()
        updateView()
    }
    function setGalleryMode() {
        viewMode = 'gallery'
        resetPage()
        updateView()
    }
    function nextPage() {
        currentPage++
        loadSongs()
    }
    function previousPage() {
        if (currentPage > 1) {
            currentPage--
            loadSongs()
        }
    }
    function setRandomSeed() {
        seedInput.value = Math.floor(Math.random() * Number.MAX_SAFE_INTEGER)
        resetPage()
    }
    languageInput.addEventListener('change', resetPage)
    seedInput.addEventListener('input', resetPage)
    likesInput.addEventListener('input', resetPage)
    window.addEventListener('scroll', loadNextGalleryPage)
    tableModeButton.addEventListener('click', setTableMode)
    galleryModeButton.addEventListener('click', setGalleryMode)
    randomSeedButton.addEventListener('click', setRandomSeed)
    nextPageButton.addEventListener('click', nextPage)
    previousPageButton.addEventListener('click', previousPage)
    updateView()
    loadSongs()
</script>
</body>
</html>